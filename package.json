{
  "name": "pirc1-standards-pro",
  "version": "2.2.0",
  "description": "The Definitive PiRC-100 Utility Standard: RFC 8785 Deterministic Validation & Hybrid PEP Security Protocol",
  "main": "dist/src/SigmoidTierLogic.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/EslaM-X/pirc1-standards-pro.git"
  },
  "keywords": [
    "Pi-Network",
    "Web3",
    "PiRC-100",
    "RFC-8785",
    "Deterministic-Validation",
    "PEP-Protocol",
    "Hybrid-Cryptography"
  ],
  "author": "EslaM-X (Lead Technical Architect)",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":100,\"functions\":100,\"lines\":100,\"statements\":100}}'",
    "test:watch": "jest --watch",
    "security-audit": "npm audit",
    "prepublishOnly": "npm run test:coverage && npm run build"
  },
  "dependencies": {
    "crypto": "^1.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  }
}
